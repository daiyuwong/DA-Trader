# ═══════════════════════════════════════════════════
#  DA TRADER — Configuration
# ═══════════════════════════════════════════════════

# ── Solana ────────────────────────────────────────
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com
WALLET_PRIVATE_KEY=your_private_key_here

# Backup RPCs (comma-separated, optional)
# Get free ones from helius.dev, quicknode.com, or alchemy.com
BACKUP_RPC_URLS=

# ── Trading Rules ─────────────────────────────────
MAX_POSITIONS=3
STOP_LOSS_PCT=0.50
TRAILING_STOP_PCT=0.30
TAKE_PROFIT_1=2.0
TAKE_PROFIT_2=5.0
MIN_SCORE_TO_TRADE=40
DAILY_LOSS_LIMIT_PCT=0.40
COOLDOWN_AFTER_LOSSES=3
COOLDOWN_MINUTES=30
MAX_POSITION_PCT=0.30

# ── Bet Sizing (USD equivalent) ──────────────────
BET_HIGH=9
BET_MED=5
BET_LOW=2.50

# ── Scanner ───────────────────────────────────────
MOMENTUM_SCAN_INTERVAL=60
MOMENTUM_MIN_AGE=300
MOMENTUM_MAX_AGE=3600
MOMENTUM_PRICE_CHANGE_MIN=0.20
MOMENTUM_PRICE_CHANGE_MAX=0.50
MOMENTUM_MAX_MCAP=500000

# ── Monitor ───────────────────────────────────────
PRICE_CHECK_INTERVAL=10
RUG_LIQUIDITY_DROP_PCT=0.70
RUG_LIQUIDITY_WINDOW=60

# ── Anti-MEV ──────────────────────────────────────
SLIPPAGE_BPS=300
PRIORITY_FEE_LAMPORTS=50000
JITO_TIP_LAMPORTS=0

# ── Dashboard ─────────────────────────────────────
DASHBOARD_PORT=5000
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PASSWORD=changeme

# ── Mode ──────────────────────────────────────────
# Set to false for real trading with real SOL
PAPER_MODE=true
LOG_LEVEL=INFO
